<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.hy.ide.cmcc.GitMockAI</id>

    <!-- Public plugin name should be written in Title Case.
     Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>GitAI助手</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <!--    <vendor url="https://www.yourcompany.com">YourCompany</vendor>-->

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        为 Git 提交创建 Mock AI 检查点，并管理提交中的 AI 归因信息。
        ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="GitMockAI Notifications"
                           displayName="GitAI助手"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
        <applicationConfigurable id="com.hy.ide.cmcc.GitMockAI.Settings"
                                 parentId="tools"
                                 displayName="Git AI 助手"
                                 instance="com.hy.ide.cmcc.MockAIConfigurable"/>
    </extensions>

    <actions>
        <group id="com.hy.ide.cmcc.GitMockAI.CommitActions" popup="false">
            <add-to-group group-id="ChangesViewPopupMenu"
                          anchor="after"
                          relative-to-action="Diff.ShowStandaloneDiff"/>
            <separator/>
            <action id="com.hy.ide.cmcc.GitMockAI.MockAI"
                    class="com.hy.ide.cmcc.MockAIAction"
                    text="标记为 AI 生成的文件"
                    description="标记当前窗口所有选中文件为 AI 生成的文件"/>
            <action id="com.hy.ide.cmcc.GitMockAI.ResetCommitAttribution"
                    class="com.hy.ide.cmcc.ResetCommitAttributionAction"
                    text="取消当前窗口所有文件的标记"
                    description="取消当前窗口所有文件的标记"/>
            <separator/>
        </group>
    </actions>

</idea-plugin>
